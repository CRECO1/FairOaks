# App
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Database (Supabase)
# IMPORTANT: Payload CMS uses Drizzle ORM which requires prepared statements.
# Transaction mode (port 6543) does NOT support prepared statements.
# You MUST use Session Pooler mode (port 5432) which DOES support prepared statements.
#
# Get connection string from: Supabase Dashboard > Project Settings > Connect > Session Pooler
# Format: postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# Password URL encoding: @ -> %40, $ -> %24, # -> %23, etc.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Payload CMS
PAYLOAD_SECRET=your-super-secret-key-change-this-in-production

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
LEAD_NOTIFICATION_EMAIL=leads@crecotx.com

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# IDX Broker (optional at first)
IDX_API_KEY=
IDX_OUTPUT_TYPE=json

# CRM Webhook (optional)
CRM_WEBHOOK_URL=

# Analytics
NEXT_PUBLIC_GA_ID=
